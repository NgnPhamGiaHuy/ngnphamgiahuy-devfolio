rules_version = '2';

// ============================================================
// Storage Security Rules — profile / project / blog images
// Public read (the live site serves them via <Image>), admin-only write,
// constrained to small raster images. SVG is excluded on purpose because
// next.config has dangerouslyAllowSVG: true. Keep the UID list in sync with
// firestore.rules allowlist() and NEXT_PUBLIC_ADMIN_UIDS.
// ============================================================
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
        && request.auth.uid in ["iF4bJcy3lQeQT7u0Ho43jsaVv582"];
    }

    // contentType is client-supplied metadata (not byte-sniffed), so an
    // explicit raster allowlist + admin-only write is the realistic ceiling.
    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType in
             ['image/png', 'image/jpeg', 'image/webp', 'image/avif'];
    }

    // Supports nested paths: images/profile/, images/projects/{slug}/, images/blog/{slug}/, images/site/
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImage();
      allow delete: if isAdmin();
    }

    // Resume / CV uploads (PDF only, max 5 MB)
    function isValidFile() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType in ['application/pdf'];
    }

    match /resume/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && isValidFile();
      allow delete: if isAdmin();
    }

    match /{allPaths=**} { allow read, write: if false; }
  }
}
